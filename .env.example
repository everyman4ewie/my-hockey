# Публичный URL сайта (без слэша в конце) — для return_url после оплаты ЮKassa и ссылок в письмах
# Локально с Vite: http://localhost:5173
# Продакшен: https://ваш-домен.ru
PUBLIC_APP_URL=http://localhost:5173

# --- Почта (сброс пароля). Рекомендуется на VPS с таймаутом SMTP: ---
# Resend (https://resend.com): API-ключ, отправка по HTTPS :443 — обходит блокировку исходящего SMTP.
# В панели Resend подключите домен и добавьте DNS-записи; «От» — тот же домен (или тест: onboarding@resend.dev).
# RESEND_API_KEY=re_xxxxxxxx
# MAIL_FROM=noreply@ваш-домен.ru
# (опционально вместо MAIL_FROM) RESEND_FROM=
#
# --- Почта через SMTP (Timeweb и др.), если с VPS доступен smtp.timeweb.ru ---
# Пароль ящика из панели хостинга; символы # % и т.д. — в кавычках: SMTP_PASS="…"
# После правок .env на сервере: pm2 restart hockey (или деплой скриптом).
# Проверка: npm run mail:verify  или  node scripts/smtp-verify.mjs
# Если verify: ETIMEDOUT — исходящий SMTP с VPS закрыт; используйте Resend выше или откройте порты в облаке.
# Логи: pm2 logs hockey | grep mail
# Timeweb (поддержка): smtp.timeweb.ru; 465+SSL или 587/2525+STARTTLS; порт 25 на VPS часто закрыт.
# Если 587 даёт таймаут — в .env попробуйте: SMTP_PORT=2525 и SMTP_SECURE=starttls
# SMTP_HOST=smtp.timeweb.ru
# SMTP_PORT=587
# SMTP_SECURE=starttls
# SMTP_USER=info@ваш-домен.ru
# SMTP_PASS=
# MAIL_FROM=info@ваш-домен.ru
# Опционально: SMTP_DEBUG=1 (очень много логов, только на время отладки)

# ЮKassa (тестовые или боевые ключи из личного кабинета)
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=

# Чек 54-ФЗ: код ставки НДС в позиции чека (1 — без НДС; 6 — НДС 20% и т.д. — см. документацию ЮKassa)
YOOKASSA_RECEIPT_VAT_CODE=1
# Система налогообложения магазина (если ЮKassa требует в чеке): 1 ОСН, 2 УСН доход, 3 УСН доход-расход…
YOOKASSA_TAX_SYSTEM_CODE=2
# YOOKASSA_RECEIPT_INTERNET=0

# Порт Node (по умолчанию 3002)
# PORT=3002

# Админ-панель: пароль хранится в server/admin.json после первого входа/смены или задаётся здесь (не коммитьте реальный пароль)
ADMIN_LOGIN=myadmin
ADMIN_PASSWORD=

# Подпись сессионных токенов (Bearer v2.*). В продакшене обязательно задайте длинную случайную строку (≥32 символов)
# SESSION_SECRET=

# Опционально: один разрешённый origin для CORS (без слэша в конце). Пусто — все источники (типично для dev с Vite proxy)
# CORS_ORIGIN=http://localhost:5173

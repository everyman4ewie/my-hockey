# Публичный URL сайта (без слэша в конце) — для return_url после оплаты ЮKassa и ссылок в письмах
# Локально с Vite: http://localhost:5173
# Продакшен: https://ваш-домен.ru
PUBLIC_APP_URL=http://localhost:5173

# ЮKassa (тестовые или боевые ключи из личного кабинета)
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=

# Чек 54-ФЗ: код ставки НДС в позиции чека (1 — без НДС; 6 — НДС 20% и т.д. — см. документацию ЮKassa)
YOOKASSA_RECEIPT_VAT_CODE=1
# Система налогообложения магазина (если ЮKassa требует в чеке): 1 ОСН, 2 УСН доход, 3 УСН доход-расход…
YOOKASSA_TAX_SYSTEM_CODE=2
# YOOKASSA_RECEIPT_INTERNET=0

# Порт Node (по умолчанию 3002)
# PORT=3002

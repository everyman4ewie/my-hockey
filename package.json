{
  "name": "hockey-tactics",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "postinstall": "node scripts/copy-ffmpeg-to-public.mjs",
    "prebuild": "node scripts/copy-ffmpeg-to-public.mjs",
    "dev": "vite",
    "dev:all": "concurrently -n \"vite,api\" -c \"cyan,magenta\" \"npm run dev\" \"npm run server\"",
    "build": "vite build",
    "preview": "vite preview",
    "server": "node server/index.js",
    "server:fresh": "lsof -ti:3002 | xargs kill -9 2>/dev/null; node server/index.js",
    "start": "npm run build && node server/index.js",
    "deploy:build": "bash scripts/deploy-production.sh",
    "deploy:server": "bash scripts/rsync-to-server.sh",
    "smtp:verify": "node scripts/smtp-verify.mjs",
    "mail:verify": "node scripts/smtp-verify.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@ffmpeg/core": "0.12.9",
    "@ffmpeg/ffmpeg": "^0.12.15",
    "@ffmpeg/util": "^0.12.2",
    "@react-three/drei": "^9.92.7",
    "@react-three/fiber": "^8.15.19",
    "async-mutex": "^0.5.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "docx": "^9.6.1",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "express-rate-limit": "^8.3.2",
    "file-saver": "^2.0.5",
    "helmet": "^8.1.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^0.577.0",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.0",
    "three": "^0.160.0"
  },
  "devDependencies": {
    "esbuild": "^0.28.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@vitejs/plugin-react": "^4.2.0",
    "@vitest/coverage-v8": "^4.1.2",
    "concurrently": "^9.1.2",
    "jsdom": "^29.0.1",
    "supertest": "^7.2.2",
    "vite": "^5.0.0",
    "vitest": "^4.1.2"
  }
}
